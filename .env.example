# Cloud AI only (Ollama disabled). Pick one provider:
DEMO_AI_PROVIDER=groq

# Groq (recommended): https://console.groq.com
DEMO_GROQ_API_KEY=
# DEMO_GROQ_MODEL=llama-3.3-70b-versatile

# Gemini: https://aistudio.google.com/apikey
DEMO_GEMINI_API_KEY=
# DEMO_GEMINI_MODEL=gemini-2.0-flash

# OpenRouter: https://openrouter.ai/keys
DEMO_OPENROUTER_API_KEY=
# DEMO_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

